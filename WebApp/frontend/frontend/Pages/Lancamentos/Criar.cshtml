@page
@using CodeBehind.Enums
@model frontend.Pages.Lancamentos.CriarModel
@{
    ViewData["Title"] = "Novo lançamento";
}

<section class="page-header mb-4">
    <div>
        <p class="eyebrow">Cadastro</p>
        <h1>Novo lançamento financeiro</h1>
    </div>
    <a class="btn btn-outline-secondary" asp-page="/Index">Voltar</a>
</section>

<section class="panel-card">
    <form method="post" class="row g-3">
        <div asp-validation-summary="ModelOnly" class="alert alert-danger mb-0"></div>

        <div class="col-12">
            <div class="form-helper">
                <strong>Regra rapida:</strong> credito usa <strong>desconto</strong> e debito usa <strong>taxa</strong>.
                Informe a competência no formato <strong>AAAA-MM</strong>.
            </div>
        </div>

        <div class="col-md-8">
            <label class="form-label" for="descricao">Descrição</label>
            <input id="descricao" name="Input.Descricao" class="form-control" value="@Model.Input.Descricao" maxlength="200" />
            <small class="text-muted">Exemplo: Mensalidade, Energia, Recebimento cliente. Máximo de 200 caracteres.</small>
        </div>

        <div class="col-md-4">
            <label class="form-label" for="competencia">Competência</label>
            <input id="competencia" name="Input.Competencia" class="form-control" placeholder="AAAA-MM" value="@Model.Input.Competencia" maxlength="7" inputmode="numeric" data-mask="competencia" />
            <small class="text-muted">Exemplo: 2026-04</small>
        </div>

        <div class="col-md-4">
            <label class="form-label" for="tipo">Tipo</label>
            <select id="tipo" name="Input.Tipo" class="form-select" data-tipo-selector>
                <option value="@((int)TipoLancamento.Credito)" selected="@(Model.Input.Tipo == TipoLancamento.Credito)">Credito</option>
                <option value="@((int)TipoLancamento.Debito)" selected="@(Model.Input.Tipo == TipoLancamento.Debito)">Debito</option>
            </select>
            <small class="text-muted" data-tipo-helper></small>
        </div>

        <div class="col-md-4">
            <label class="form-label" for="valorOriginal">Valor original</label>
            <input id="valorOriginal" name="Input.ValorOriginal" class="form-control" type="text" inputmode="decimal" data-mask="decimal" data-min="0.01" value="@(Model.Input.ValorOriginal > 0 ? Model.Input.ValorOriginal.ToString("0.00", System.Globalization.CultureInfo.InvariantCulture) : string.Empty)" />
            <small class="text-muted">Informe um valor maior que zero.</small>
        </div>

        <div class="col-md-4">
            <label class="form-label" for="dataLancamento">Data lançamento</label>
            <input id="dataLancamento" name="Input.DataLancamento" class="form-control" type="datetime-local" value="@Model.Input.DataLancamento.ToString("yyyy-MM-ddTHH:mm")" />
        </div>

        <div class="col-md-6" data-field-group="taxa">
            <label class="form-label" for="percentualTaxa">Percentual taxa</label>
            <input id="percentualTaxa" name="Input.PercentualTaxa" class="form-control" type="text" inputmode="decimal" data-mask="decimal" data-min="0" data-max="100" value="@(Model.Input.PercentualTaxa?.ToString("0.00", System.Globalization.CultureInfo.InvariantCulture) ?? "0")" />
            <small class="text-muted">Preencha somente quando o tipo for débito.</small>
        </div>

        <div class="col-md-6" data-field-group="desconto">
            <label class="form-label" for="percentualDesconto">Percentual desconto</label>
            <input id="percentualDesconto" name="Input.PercentualDesconto" class="form-control" type="text" inputmode="decimal" data-mask="decimal" data-min="0" data-max="100" value="@(Model.Input.PercentualDesconto?.ToString("0.00", System.Globalization.CultureInfo.InvariantCulture) ?? string.Empty)" />
            <small class="text-muted">Preencha somente quando o tipo for crédito.</small>
        </div>

        <div class="col-12 d-flex gap-2">
            <button type="submit" class="btn btn-primary">Salvar</button>
            <a class="btn btn-outline-secondary" asp-page="/Index">Cancelar</a>
        </div>
    </form>
</section>

@section Scripts {
    <script>
        window.inputMasks && window.inputMasks();
        window.lancamentoForm && window.lancamentoForm();
    </script>
}
