@page
@using CodeBehind.Enums
@model frontend.Pages.Lancamentos.CriarModel
@{
    ViewData["Title"] = "Novo lancamento";
}

<section class="page-header mb-4">
    <div>
        <p class="eyebrow">Cadastro</p>
        <h1>Novo lancamento financeiro</h1>
    </div>
    <a class="btn btn-outline-secondary" asp-page="/Index">Voltar</a>
</section>

<section class="panel-card">
    <form method="post" class="row g-3">
        <div asp-validation-summary="ModelOnly" class="text-danger"></div>

        <div class="col-md-8">
            <label class="form-label" for="descricao">Descricao</label>
            <input id="descricao" name="Input.Descricao" class="form-control" value="@Model.Input.Descricao" />
        </div>

        <div class="col-md-4">
            <label class="form-label" for="competencia">Competencia</label>
            <input id="competencia" name="Input.Competencia" class="form-control" placeholder="AAAA-MM" value="@Model.Input.Competencia" />
        </div>

        <div class="col-md-4">
            <label class="form-label" for="tipo">Tipo</label>
            <select id="tipo" name="Input.Tipo" class="form-select">
                <option value="@((int)TipoLancamento.Credito)" selected="@(Model.Input.Tipo == TipoLancamento.Credito)">Credito</option>
                <option value="@((int)TipoLancamento.Debito)" selected="@(Model.Input.Tipo == TipoLancamento.Debito)">Debito</option>
            </select>
        </div>

        <div class="col-md-4">
            <label class="form-label" for="valorOriginal">Valor original</label>
            <input id="valorOriginal" name="Input.ValorOriginal" class="form-control" type="number" step="0.01" value="@Model.Input.ValorOriginal.ToString("0.00", System.Globalization.CultureInfo.InvariantCulture)" />
        </div>

        <div class="col-md-4">
            <label class="form-label" for="dataLancamento">Data lancamento</label>
            <input id="dataLancamento" name="Input.DataLancamento" class="form-control" type="datetime-local" value="@Model.Input.DataLancamento.ToString("yyyy-MM-ddTHH:mm")" />
        </div>

        <div class="col-md-6">
            <label class="form-label" for="percentualTaxa">Percentual taxa</label>
            <input id="percentualTaxa" name="Input.PercentualTaxa" class="form-control" type="number" step="0.01" value="@(Model.Input.PercentualTaxa?.ToString("0.00", System.Globalization.CultureInfo.InvariantCulture) ?? string.Empty)" />
            <small class="text-muted">Use apenas para debito.</small>
        </div>

        <div class="col-md-6">
            <label class="form-label" for="percentualDesconto">Percentual desconto</label>
            <input id="percentualDesconto" name="Input.PercentualDesconto" class="form-control" type="number" step="0.01" value="@(Model.Input.PercentualDesconto?.ToString("0.00", System.Globalization.CultureInfo.InvariantCulture) ?? string.Empty)" />
            <small class="text-muted">Use apenas para credito.</small>
        </div>

        <div class="col-12 d-flex gap-2">
            <button type="submit" class="btn btn-primary">Salvar</button>
        </div>
    </form>
</section>
