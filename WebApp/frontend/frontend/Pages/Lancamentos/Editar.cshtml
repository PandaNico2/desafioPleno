@page "{id:int}"
@model frontend.Pages.Lancamentos.EditarModel
@{
    ViewData["Title"] = "Editar lançamento";
}

<section class="page-header mb-4">
    <div>
        <p class="eyebrow">Edição</p>
        <h1>Editar lançamento</h1>
    </div>
    <a class="btn btn-outline-secondary" asp-page="/Index">Voltar</a>
</section>

<section class="panel-card">
    <form method="post" class="row g-3">
        <div asp-validation-summary="ModelOnly" class="alert alert-danger mb-0"></div>

        <input type="hidden" name="Id" value="@Model.Id" />

        <div class="col-12">
            <div class="form-helper">
                <strong>Regra rapida:</strong> apenas lancamentos em <strong>aberto</strong> podem ser editados.
                Credito usa <strong>desconto</strong> e debito usa <strong>taxa</strong>.
            </div>
        </div>

        <div class="col-md-8">
            <label class="form-label" for="descricao">Descrição</label>
            <input id="descricao" name="Input.Descricao" class="form-control" value="@Model.Input.Descricao" maxlength="200" />
            <small class="text-muted">Máximo de 200 caracteres.</small>
            <span class="text-danger" asp-validation-for="Input.Descricao"></span>
        </div>

        <div class="col-md-4">
            <label class="form-label" for="competencia">Competência</label>
            <input id="competencia" name="Input.Competencia" class="form-control" value="@Model.Input.Competencia" placeholder="AAAA-MM" maxlength="7" inputmode="numeric" data-mask="competencia" />
            <span class="text-danger" asp-validation-for="Input.Competencia"></span>
        </div>

        <div class="col-md-4">
            <label class="form-label" for="tipo">Tipo</label>
            <select id="tipo" name="Input.Tipo" class="form-select" data-tipo-selector asp-items="Model.Tipos"></select>
            <small class="text-muted" data-tipo-helper></small>
            <span class="text-danger" asp-validation-for="Input.Tipo"></span>
        </div>

        <div class="col-md-4">
            <label class="form-label" for="valorOriginal">ValorOriginal</label>
            <input id="valorOriginal" name="Input.ValorOriginal" class="form-control" type="text" inputmode="decimal" data-mask="decimal" data-min="0.01" value="@Model.Input.ValorOriginal.ToString("0.00", System.Globalization.CultureInfo.InvariantCulture)" />
            <span class="text-danger" asp-validation-for="Input.ValorOriginal"></span>
        </div>

        <div class="col-md-4">
            <label class="form-label" for="dataLancamento">Data lançamento</label>
            <input id="dataLancamento" name="Input.DataLancamento" class="form-control" type="datetime-local" value="@Model.Input.DataLancamento.ToString("yyyy-MM-ddTHH:mm")" />
            <span class="text-danger" asp-validation-for="Input.DataLancamento"></span>
        </div>

        <div class="col-md-6" data-field-group="taxa">
            <label class="form-label" for="percentualTaxa">PercentualTaxa</label>
            <input id="percentualTaxa" name="Input.PercentualTaxa" class="form-control" type="text" inputmode="decimal" data-mask="decimal" data-min="0" data-max="100" value="@(Model.Input.PercentualTaxa?.ToString("0.00", System.Globalization.CultureInfo.InvariantCulture) ?? "0")" />
            <small class="text-muted">Use apenas para débito.</small>
            <span class="text-danger" asp-validation-for="Input.PercentualTaxa"></span>
        </div>

        <div class="col-md-6" data-field-group="desconto">
            <label class="form-label" for="percentualDesconto">PercentualDesconto</label>
            <input id="percentualDesconto" name="Input.PercentualDesconto" class="form-control" type="text" inputmode="decimal" data-mask="decimal" data-min="0" data-max="100" value="@(Model.Input.PercentualDesconto?.ToString("0.00", System.Globalization.CultureInfo.InvariantCulture) ?? string.Empty)" />
            <small class="text-muted">Use apenas para crédito.</small>
            <span class="text-danger" asp-validation-for="Input.PercentualDesconto"></span>
        </div>

        <div class="col-12 d-flex gap-2">
            <button type="submit" class="btn btn-primary">Salvar alterações</button>
            <a class="btn btn-outline-secondary" asp-page="/Index">Cancelar</a>
        </div>
    </form>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        window.inputMasks && window.inputMasks();
        window.lancamentoForm && window.lancamentoForm();
    </script>
}
