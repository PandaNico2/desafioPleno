@page
@model IndexModel
@{
    ViewData["Title"] = "Lançamentos";
}

<section class="hero-card mb-4">
    <div>
        <p class="eyebrow">Desafio tecnico</p>
        <h1>Controle de lançamentos financeiros</h1>
        <p class="hero-copy">Cadastre os lançamentos, acompanhe o saldo dos itens pagos e execute pagamento, cancelamento e exportação por competência.</p>
    </div>
    <div class="hero-actions">
        <a class="btn btn-primary btn-lg" asp-page="/Lancamentos/Criar">Novo lançamento</a>
    </div>
</section>

@if (!string.IsNullOrWhiteSpace(Model.Mensagem))
{
    <div class="alert alert-success" role="alert">@Model.Mensagem</div>
}

@if (!string.IsNullOrWhiteSpace(Model.Erro))
{
    <div class="alert alert-danger" role="alert">@Model.Erro</div>
}

<section class="row g-3 mb-4">
    <div class="col-md-4">
        <div class="stat-card">
            <span class="stat-label">Saldo de pagos</span>
            <strong>@Model.Saldo.ToString("C")</strong>
        </div>
    </div>
    <div class="col-md-4">
        <div class="stat-card">
            <span class="stat-label">Total listado</span>
            <strong>@Model.Lancamentos.Count</strong>
        </div>
    </div>
    <div class="col-md-4">
        <div class="stat-card">
            <span class="stat-label">Filtro atual</span>
            <strong>@(string.IsNullOrWhiteSpace(Model.Competencia) ? "Todas" : Model.Competencia)</strong>
        </div>
    </div>
</section>

<section class="panel-card mb-4">
    <form method="get" asp-page="/Index" class="row g-3">
        <div class="col-md-4">
            <label class="form-label" asp-for="Competencia">Competência</label>
            <input class="form-control" asp-for="Competencia" placeholder="AAAA-MM" maxlength="7" inputmode="numeric" data-mask="competencia" />
            <small class="text-muted">Use o filtro para localizar um mês específico e exportar CSV.</small>
        </div>
        <div class="col-md-3">
            <label class="form-label" asp-for="Tipo">Tipo</label>
            <select class="form-select" asp-for="Tipo" asp-items="Model.Tipos"></select>
        </div>
        <div class="col-md-3">
            <label class="form-label" asp-for="Status">Status</label>
            <select class="form-select" asp-for="Status" asp-items="Model.Statuses"></select>
        </div>
        <div class="col-12 d-flex gap-2 flex-wrap">
            <button type="submit" class="btn btn-outline-primary">Filtrar</button>
            <a class="btn btn-outline-secondary" asp-page="/Index">Limpar</a>
            <button type="submit" class="btn btn-outline-success" name="handler" value="Exportar">Exportar CSV</button>
        </div>
    </form>
</section>

<section class="panel-card">
    <div class="section-title-row">
        <div>
            <h2 class="section-title">Lançamentos cadastrados</h2>
            <p class="section-subtitle">Ações de pagamento e cancelamento aparecem apenas para itens em aberto.</p>
        </div>
    </div>
    <div class="table-responsive">
        <table class="table align-middle">
            <thead>
                <tr>
                    <th>Descrição</th>
                    <th>Competência</th>
                    <th>Tipo</th>
                    <th>Status</th>
                    <th>Valor Original</th>
                    <th>Valor Calculado</th>
                    <th>Data Lançamento</th>
                    <th>Ações</th>
                </tr>
            </thead>
            <tbody>
            @if (Model.Lancamentos.Count == 0)
            {
                <tr>
                    <td colspan="8" class="text-center text-muted py-4">Nenhum lançamento encontrado.</td>
                </tr>
            }
            else
            {
                @foreach (var item in Model.Lancamentos)
                {
                    <tr>
                        <td>
                            <strong>@item.Descricao</strong>
                            <div class="text-muted small">@item.DataCriacao.ToString("dd/MM/yyyy HH:mm")</div>
                        </td>
                        <td>@item.Competencia</td>
                        <td><span class="type-pill type-@item.Tipo.ToString().ToLowerInvariant()">@item.Tipo</span></td>
                        <td><span class="status-pill status-@item.Status.ToString().ToLowerInvariant()">@item.Status</span></td>
                        <td>@item.ValorOriginal.ToString("C")</td>
                        <td>@item.ValorCalculado.ToString("C")</td>
                        <td>@item.DataLancamento.ToString("dd/MM/yyyy HH:mm")</td>
                        <td class="actions-cell">
                            @if (item.Status == CodeBehind.Enums.StatusLancamento.Aberto)
                            {
                                <a class="btn btn-sm btn-outline-primary" asp-page="/Lancamentos/Editar" asp-route-id="@item.Id">Editar</a>
                                <a class="btn btn-sm btn-outline-success" asp-page="/Lancamentos/Pagar" asp-route-id="@item.Id">
                                    @(item.Tipo == CodeBehind.Enums.TipoLancamento.Credito ? "Receber" : "Pagar")
                                </a>
                                <a class="btn btn-sm btn-outline-danger" asp-page="/Lancamentos/Cancelar" asp-route-id="@item.Id">Cancelar</a>
                            }
                        </td>
                    </tr>
                }
            }
            </tbody>
        </table>
    </div>
</section>

@section Scripts {
    <script>
        window.inputMasks && window.inputMasks();
    </script>
}
